# ============================================================================
# Environment Configuration
# ============================================================================
# This file contains all environment variables needed for the application.
# Copy this file to .env.local and fill in your actual values.
#
# IMPORTANT: Never commit .env.local to version control!
#
# For type-safe environment validation, see src/env.ts
# Powered by @t3-oss/env-nextjs and dotenv-cli
# ============================================================================

# ----------------------------------------------------------------------------
# Required Variables
# ----------------------------------------------------------------------------

# Database (PostgreSQL connection string)
# Get this from Supabase: Project Settings > Database > Connection String (Direct connection)
# Or use any PostgreSQL database provider
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Better Auth Secret (REQUIRED - minimum 32 characters)
# Generate a secure random string using: openssl rand -base64 32
# Or run: pnpm setup (will auto-generate)
BETTER_AUTH_SECRET=your_random_secret_string_min_32_characters

# ----------------------------------------------------------------------------
# Optional Variables
# ----------------------------------------------------------------------------

# App Configuration
# The public URL of your application (defaults to http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (Optional - for Google sign-in)
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend Email Service (Required for email verification)
# Get your API key from: https://resend.com/api-keys
# For development, you can use Resend's testing domain
RESEND_API_KEY=re_your_resend_api_key_here
# Upstash Redis (Required - for rate limiting and caching)
# Get these from: https://console.upstash.com/redis
# 1. Create a Redis database
# 2. Copy the REST URL and REST Token from the database details
UPSTASH_REDIS_REST_URL=https://your-redis-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# Cron Job Secret (Optional - for securing cron endpoints)
# Generate a secure random string using: openssl rand -base64 32
# This protects your cron endpoints from unauthorized access
CRON_SECRET=your_cron_secret_here

# Supabase Client Configuration (Optional - only if using Supabase client directly)
# Get these from Supabase: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ----------------------------------------------------------------------------
# SWIPE - Wholesale Sales OS
# ----------------------------------------------------------------------------

# OpenAI API Key (Required for AI features)
# Option 1: Get from https://platform.openai.com/api-keys
# Option 2: Enable AI on Vercel dashboard (Settings > AI) - key auto-provided
OPENAI_API_KEY=sk-your_openai_api_key_here

# Trigger.dev (Required for background jobs)
# Get these from: https://trigger.dev/dashboard
# 1. Create a project
# 2. Get your API key from Settings > API Keys
TRIGGER_SECRET_KEY=tr_dev_your_trigger_secret_key

# Meta / Instagram (Required for Instagram DM integration)
# Get these from: https://developers.facebook.com/apps
# 1. Create a Meta App
# 2. Add Instagram Messaging product
# 3. Get App Secret from Settings > Basic
META_APP_SECRET=your_meta_app_secret
META_WEBHOOK_VERIFY_TOKEN=your_custom_verify_token

# Shopify (Required for order management)
# Get these from: https://partners.shopify.com/
# 1. Create a Shopify Partner app
# 2. Get Client ID and Secret from App Setup
SHOPIFY_CLIENT_ID=your_shopify_client_id
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret

# ----------------------------------------------------------------------------
# Development & Build
# ----------------------------------------------------------------------------

# Skip environment validation during build (useful for Docker builds)
# SKIP_ENV_VALIDATION=true
